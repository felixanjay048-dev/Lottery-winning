user = {}

def register():

    username = input("Berikan user name anda! ")

    if username in user:

        print("Username sudah ada di dalam list, silahkan coba lagi! ")

    else:

        password = input("Berikan password anda: ")

        user[username] = password

        user.update({username : password})

        print("Registrasi Berhasil! ")

        return username and password
    
def login():

    username = input("Berikan username anda, yang sudah terdaftar: ")

    password = input("Berikan Password anda, yang sudah terdaftar: ")

    if username in user and user[username] == password:

        print(f"Login Berhasil! Selamat datang! {username}")

    else:

        print("User, atau Password salah, silah kan cobalagi! ")

while True:

    print("Pilih Menu: 1. Registrasi, 2. Login, 3. Keluar")

    choice = int(input("Pilih salah satu yang ada di dalam menu: "))

    if choice == 1:

        register()

    elif choice == 2:

        login()

    else:

        break
