import secrets

# Contoh daftar kata (BIP39 aslinya ada 2048 kata)
# Kamu bisa ambil daftar lengkapnya di GitHub (search: BIP39 english wordlist)
wordlist = [
    "abandon", "ability", "able", "about", "above", "absent", "absorb", "abstract", 
    "absurd", "abuse", "access", "accident", "account", "accuse", "achieve", "acid",
    "acoustic", "acquire", "across", "act", "action", "actor", "actress", "actual",
    "adapt", "add", "addict", "address", "adjust", "admit", "adult", "advance"
    # ... teruskan sampai 2048 kata
]

def generate_seed(jumlah_kata=12):
    seed = []
    for _ in range(jumlah_kata):
        # Menggunakan secrets.choice agar acak secara kriptografis (aman)
        kata = secrets.choice(wordlist)
        seed.append(kata)
    
    return " ".join(seed)

# Jalankan generator
my_seed = generate_seed(12)
print("Seed Phrase Anda:")

print(my_seed)
