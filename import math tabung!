import math

choice = input("Pilih salah satu Keliling, atau Luas: ")

def tabung_luas():

    radius = float(input("Berikan salah satu angka untuk radius: "))

    tinggi = float(input("Berikan salah satu angka untuk tinggi: "))

    volume = math.pi * math.pow(radius, 2) * tinggi

    return volume

def tabung_keliling():

    radius = float(input("Berikan salah saut angka untuk radius: "))

    volume = 2 * math.pi * math.pow(radius, 2)

    return volume

if choice.lower() == "keliling":

    print("Ini adalah hasilnya: ", round(tabung_keliling()), "m**3")

elif choice.lower() == "luas":

    print("Ini adalah hasilnya: ", round(tabung_luas()), "m**3")

else:

    print("Terjadi error, silahkan coba lagi! ")
